# =============================================================================
# .env.example — Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL connection
# -----------------------------------------------------------------------------
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
#   user     : your PostgreSQL username (default: postgres)
#   password : your PostgreSQL password (omit if using peer/trust auth locally)
#   host     : DB host (localhost for local dev)
#   port     : DB port (default: 5432)
#   database : database name (create with: psql -c "CREATE DATABASE agentic_ta;")
#
# Examples:
#   postgresql://postgres:mypassword@localhost:5432/agentic_ta   ← with password
#   postgresql://localhost/agentic_ta                            ← peer auth (macOS default)
DATABASE_URL=postgresql://postgres:password@localhost:5432/agentic_ta

# -----------------------------------------------------------------------------
# Ollama local LLM server
# -----------------------------------------------------------------------------
# OLLAMA_BASE_URL : URL where the Ollama server is running.
#                  Default is localhost. Do NOT change unless running Ollama
#                  on a remote machine or a different port.
OLLAMA_BASE_URL=http://localhost:11434

# OLLAMA_MODEL : Model tag to use for feedback generation.
#                Must be already pulled: run `ollama pull <model>` first.
#                Confirmed working: llama3.2 (~2.0 GB)
OLLAMA_MODEL=llama3.2

# OLLAMA_PROMPT_VERSION : Version tag for the prompt template used in
#                         _build_prompt() inside app/llm/ollama_client.py.
#                         Stored in llm_feedback_draft.prompt_version so that
#                         DB records remain traceable to the exact prompt used.
#                         Bump this (e.g. v1.1) whenever you change the prompt.
OLLAMA_PROMPT_VERSION=v1.0

# OLLAMA_REQUEST_TIMEOUT_SEC : How many seconds to wait for Ollama to respond
#                              before raising OllamaUnavailableError.
#                              Increase if your machine is slow or the model
#                              is large. 120 seconds is sufficient for llama3.2.
OLLAMA_REQUEST_TIMEOUT_SEC=120

# -----------------------------------------------------------------------------
# Local object storage
# -----------------------------------------------------------------------------
# LOCAL_STORAGE_ROOT : Root directory for the LocalStorageAdapter.
#                      Student code files and test result JSONs are saved here.
#                      The folder is created automatically on first run.
#                      Path can be relative (to project root) or absolute.
#                      Do NOT point this at a cloud-synced folder (e.g. iCloud,
#                      Google Drive) to avoid file-lock issues during tests.
LOCAL_STORAGE_ROOT=./storage
